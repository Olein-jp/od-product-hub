{
  "name": "od-product-hub",
  "version": "0.1.0",
  "private": true,
  "description": "Development environment for the OD Product Hub WordPress plugin.",
  "engines": {
    "node": ">=20.18.0"
  },
  "scripts": {
    "env:start": "wp-env start",
    "env:stop": "wp-env stop",
    "env:destroy": "wp-env destroy",
    "env:logs": "wp-env logs",
    "env:cli": "wp-env run cli wp",
    "test:database": "wp-env run tests-cli wp eval-file wp-content/plugins/od-product-hub/tests/integration/database.php",
    "test:webhook": "wp-env run tests-cli wp eval-file wp-content/plugins/od-product-hub/tests/integration/webhook.php",
    "test:email": "wp-env run tests-cli wp eval-file wp-content/plugins/od-product-hub/tests/integration/email.php",
    "test:checkout": "wp-env run tests-cli wp eval-file wp-content/plugins/od-product-hub/tests/integration/checkout.php",
    "test:account": "wp-env run tests-cli wp eval-file wp-content/plugins/od-product-hub/tests/integration/account.php",
    "test:api": "wp-env run tests-cli wp eval-file wp-content/plugins/od-product-hub/tests/integration/api.php",
    "lint:php": "find . -path ./vendor -prune -o -path ./node_modules -prune -o -name '*.php' -exec php -l {} +",
    "test": "npm run lint:php"
  },
  "devDependencies": {
    "@wordpress/env": "^11.9.0"
  }
}
