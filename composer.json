{
  "name": "olein-design/od-product-hub",
  "description": "Stripe-backed contract verification and license management for WordPress products.",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": ">=8.3",
    "stripe/stripe-php": "^20.3"
  },
  "require-dev": {
    "phpstan/phpstan": "^2.1",
    "php-stubs/wordpress-stubs": "^7.0",
    "phpunit/phpunit": "^11.0",
    "squizlabs/php_codesniffer": "^3.13",
    "wp-coding-standards/wpcs": "^3.2",
    "yoast/phpunit-polyfills": "^4.0"
  },
  "autoload": {
    "psr-4": {
      "OD_Product_Hub\\": "includes/",
      "OD_Product_Hub_Client\\": "packages/client-sdk/src/"
    }
  },
  "autoload-dev": {
    "psr-4": {"OD_Product_Hub\\Tests\\": "tests/"}
  },
  "scripts": {
    "lint": "phpcs",
    "phpstan": "phpstan analyse --memory-limit=2G --debug",
    "test": "phpunit",
    "quality": "scripts/quality-all.sh"
  },
  "config": {
    "allow-plugins": {"dealerdirect/phpcodesniffer-composer-installer": true},
    "sort-packages": true
  }
}
