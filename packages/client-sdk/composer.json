{
  "name": "olein-design/od-product-hub-client",
  "description": "WordPress client SDK for OD Product Hub contract verification.",
  "type": "library",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": ">=8.1"
  },
  "require-dev": {
    "php-stubs/wordpress-stubs": "^7.0",
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^10.5 || ^11.0",
    "squizlabs/php_codesniffer": "^3.13",
    "wp-coding-standards/wpcs": "^3.2"
  },
  "autoload": {
    "psr-4": {
      "OD_Product_Hub_Client\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "OD_Product_Hub_Client\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "syntax": "find src tests -name '*.php' -exec php -l {} +",
    "lint": "phpcs",
    "phpstan": "phpstan analyse --memory-limit=1G --debug",
    "test": "phpunit",
    "quality": [
      "@syntax",
      "@lint",
      "@phpstan",
      "@test"
    ]
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    },
    "sort-packages": true
  }
}
