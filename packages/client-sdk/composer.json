{
  "name": "olein-design/od-product-hub-client",
  "description": "WordPress client SDK for OD Product Hub contract verification.",
  "type": "library",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": ">=8.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5 || ^11.0"
  },
  "autoload": {
    "psr-4": {
      "OD_Product_Hub_Client\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "OD_Product_Hub_Client\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit"
  },
  "config": {
    "sort-packages": true
  }
}
